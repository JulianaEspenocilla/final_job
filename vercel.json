{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "public/index.php",
            "use": "@vercel/php"
        }
    ],
    "routes": [
        {
            "src": "/_next/static/(.*)",
            "dest": "public/_next/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ]
}
